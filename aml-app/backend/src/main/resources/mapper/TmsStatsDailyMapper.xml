<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.aml.mapper.TmsStatsDailyMapper">

    <resultMap id="StatsDailyResultMap" type="com.aml.domain.TmsStatsDaily">
        <result property="statsDt"        column="STATS_DT"/>
        <result property="totalAlerts"    column="TOTAL_ALERTS"/>
        <result property="newAlerts"      column="NEW_ALERTS"/>
        <result property="reviewAlerts"   column="REVIEW_ALERTS"/>
        <result property="closedAlerts"   column="CLOSED_ALERTS"/>
        <result property="strCount"       column="STR_COUNT"/>
        <result property="ctrCount"       column="CTR_COUNT"/>
        <result property="highRiskCount"  column="HIGH_RISK_COUNT"/>
        <result property="totalDetectAmt" column="TOTAL_DETECT_AMT"/>
    </resultMap>

    <select id="findRecentDays" resultMap="StatsDailyResultMap">
        SELECT STATS_DT, TOTAL_ALERTS, NEW_ALERTS, REVIEW_ALERTS, CLOSED_ALERTS,
               STR_COUNT, CTR_COUNT, HIGH_RISK_COUNT, TOTAL_DETECT_AMT
        FROM TMS_STATS_DAILY
        ORDER BY STATS_DT DESC
        LIMIT #{days}
    </select>

    <select id="findByDate" resultMap="StatsDailyResultMap">
        SELECT STATS_DT, TOTAL_ALERTS, NEW_ALERTS, REVIEW_ALERTS, CLOSED_ALERTS,
               STR_COUNT, CTR_COUNT, HIGH_RISK_COUNT, TOTAL_DETECT_AMT
        FROM TMS_STATS_DAILY
        WHERE STATS_DT = #{statsDt}
    </select>

</mapper>
