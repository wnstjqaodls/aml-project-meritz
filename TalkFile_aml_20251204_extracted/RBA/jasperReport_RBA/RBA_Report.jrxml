		<parameter name="BAS_YYMM" class="java.lang.String"/>
		<queryString>
			<![CDATA[SELECT BAS_YYMM
 , ACT_BASIC
 , ACT_SCHD
 , EVL_TERM
 , EVL_BRNO
 , EVL_SYSTEM
 , SUBSTR(ALL_BAS_YYYY,1,4) || '년 ' || SUBSTR(ALL_BAS_YYYY,5,6) || '회차' AS ALL_BAS_YYYY
 , ALL_RISK_VAL || '점' AS ALL_RISK_VAL
 , ALL_TONGJE_VAL || '%' AS ALL_TONGJE_VAL
 , ALL_REMDR_VAL || '점' AS ALL_REMDR_VAL
 , CASE WHEN ALL_RISK_WAY = '▲' THEN '상승(▲)' 
        WHEN ALL_RISK_WAY = '▼' THEN '하락(▼)'
        ELSE '유지' END AS ALL_RISK_WAY
 , CASE WHEN ALL_TONGJE_WAY = '▲' THEN '상승(▲)' 
        WHEN ALL_TONGJE_WAY = '▼' THEN '하락(▼)'
        ELSE '유지' END AS ALL_TONGJE_WAY
 , CASE WHEN ALL_REMDR_WAY = '▲' THEN '상승(▲)' 
        WHEN ALL_REMDR_WAY = '▼' THEN '하락(▼)'
        ELSE '유지' END AS ALL_REMDR_WAY
 , ALL_NOTE
 , SUBSTR(ALL_PRE_BAS_YYYY,1,4) || '년 ' || SUBSTR(ALL_PRE_BAS_YYYY,5,6) || '회차' AS ALL_PRE_BAS_YYYY
 , ALL_PRE_RISK_VAL || '점' AS ALL_PRE_RISK_VAL
 , ALL_PRE_TONGJE_VAL || '%' AS ALL_PRE_TONGJE_VAL
 , ALL_PRE_REMDR_VAL || '점' AS ALL_PRE_REMDR_VAL
 , SUBSTR(ALL_PRE_BAS_YYYY,1,4) || '년 ' || SUBSTR(ALL_PRE_BAS_YYYY,5,6) || '회차' AS ALL_PRE_BAS_YYYY
 , SUBSTR(REMDR_BAS_YYYY,1,4) || '년 ' || SUBSTR(REMDR_BAS_YYYY,5,6) || '회차' AS REMDR_BAS_YYYY
 , CASE WHEN REMDR_R1_VAL - REMDR_R1_PRE_VAL > 0 THEN REMDR_R1_VAL || '개 부점(' || (REMDR_R1_VAL - REMDR_R1_PRE_VAL) || '개 증가)'
        WHEN REMDR_R1_VAL - REMDR_R1_PRE_VAL = 0 THEN REMDR_R1_VAL || '개 부점(유지)'
        ELSE  REMDR_R1_VAL || '개 부점(' || (REMDR_R1_PRE_VAL - REMDR_R1_VAL) || '개 감소)' END AS REMDR_R1_VAL
 , CASE WHEN REMDR_R2_VAL - REMDR_R2_PRE_VAL > 0 THEN REMDR_R2_VAL || '개 부점(' || (REMDR_R2_VAL - REMDR_R2_PRE_VAL) || '개 증가)'
        WHEN REMDR_R2_VAL - REMDR_R2_PRE_VAL = 0 THEN REMDR_R2_VAL || '개 부점(유지)'
        ELSE  REMDR_R2_VAL || '개 부점(' || (REMDR_R2_PRE_VAL - REMDR_R2_VAL) || '개 감소)' END AS REMDR_R2_VAL
 , CASE WHEN REMDR_R3_VAL - REMDR_R3_PRE_VAL > 0 THEN REMDR_R3_VAL || '개 부점(' || (REMDR_R3_VAL - REMDR_R3_PRE_VAL) || '개 증가)'
        WHEN REMDR_R3_VAL - REMDR_R3_PRE_VAL = 0 THEN REMDR_R3_VAL || '개 부점(유지)'
        ELSE  REMDR_R3_VAL || '개 부점(' || (REMDR_R3_PRE_VAL - REMDR_R3_VAL) || '개 감소)' END AS REMDR_R3_VAL
 , CASE WHEN REMDR_R4_VAL - REMDR_R4_PRE_VAL > 0 THEN REMDR_R4_VAL || '개 부점(' || (REMDR_R4_VAL - REMDR_R4_PRE_VAL) || '개 증가)'
        WHEN REMDR_R4_VAL - REMDR_R4_PRE_VAL = 0 THEN REMDR_R4_VAL || '개 부점(유지)'
        ELSE  REMDR_R4_VAL || '개 부점(' || (REMDR_R4_PRE_VAL - REMDR_R4_VAL) || '개 감소)' END AS REMDR_R4_VAL
 , CASE WHEN REMDR_R5_VAL - REMDR_R5_PRE_VAL > 0 THEN REMDR_R5_VAL || '개 부점(' || (REMDR_R5_VAL - REMDR_R5_PRE_VAL) || '개 증가)'
        WHEN REMDR_R5_VAL - REMDR_R5_PRE_VAL = 0 THEN REMDR_R5_VAL || '개 부점(유지)'
        ELSE  REMDR_R5_VAL || '개 부점(' || (REMDR_R5_PRE_VAL - REMDR_R5_VAL) || '개 감소)' END AS REMDR_R5_VAL
 , REMDR_R1_PRE_VAL || '개 부점' AS REMDR_R1_PRE_VAL
 , REMDR_R2_PRE_VAL || '개 부점' AS REMDR_R2_PRE_VAL
 , REMDR_R3_PRE_VAL || '개 부점' AS REMDR_R3_PRE_VAL
 , REMDR_R4_PRE_VAL || '개 부점' AS REMDR_R4_PRE_VAL
 , REMDR_R5_PRE_VAL || '개 부점' AS REMDR_R5_PRE_VAL
 , REMDR_NOTE
 , (SELECT B.DPRT_NM FROM NIC41B B WHERE B.DPRT_CD = TOP1_BRNO) AS TOP1_BRNO
 , SUBSTR(TOP1_BAS_YYYY,1,4) || '년 ' || SUBSTR(TOP1_BAS_YYYY,5,6) || '회차' AS TOP1_BAS_YYYY
 , TOP1_RISK_VAL || '점' AS TOP1_RISK_VAL
 , TOP1_TONGJE_VAL || '%' AS TOP1_TONGJE_VAL
 , TOP1_REMDR_VAL || '점' AS TOP1_REMDR_VAL
 , TOP1_RISK_WAY
 , TOP1_TONGJE_WAY
 , TOP1_REMDR_WAY
 , SUBSTR(TOP1_PRE_BAS_YYYY,1,4) || '년 ' || SUBSTR(TOP1_PRE_BAS_YYYY,5,6) || '회차' AS TOP1_PRE_BAS_YYYY
 , TOP1_PRE_RISK_VAL || '점' AS TOP1_PRE_RISK_VAL
 , TOP1_PRE_TONGJE_VAL || '%' AS TOP1_PRE_TONGJE_VAL
 , TOP1_PRE_REMDR_VAL || '점' AS TOP1_PRE_REMDR_VAL
 , (SELECT B.DPRT_NM FROM NIC41B B WHERE B.DPRT_CD = TOP2_BRNO) AS TOP2_BRNO
 , SUBSTR(TOP2_BAS_YYYY,1,4) || '년 ' || SUBSTR(TOP2_BAS_YYYY,5,6) || '회차' AS TOP2_BAS_YYYY
 , TOP2_RISK_VAL || '점' AS TOP2_RISK_VAL
 , TOP2_TONGJE_VAL || '%' AS TOP2_TONGJE_VAL
 , TOP2_REMDR_VAL || '점' AS TOP2_REMDR_VAL
 , TOP2_RISK_WAY
 , TOP2_TONGJE_WAY
 , TOP2_REMDR_WAY
 , SUBSTR(TOP2_PRE_BAS_YYYY,1,4) || '년 ' || SUBSTR(TOP2_PRE_BAS_YYYY,5,6) || '회차' AS TOP2_PRE_BAS_YYYY
 , TOP2_PRE_RISK_VAL || '점' AS TOP2_PRE_RISK_VAL
 , TOP2_PRE_TONGJE_VAL || '%' AS TOP2_PRE_TONGJE_VAL
 , TOP2_PRE_REMDR_VAL || '점' AS TOP2_PRE_REMDR_VAL
 , (SELECT B.DPRT_NM FROM NIC41B B WHERE B.DPRT_CD = TOP3_BRNO) AS TOP3_BRNO
 , SUBSTR(TOP3_BAS_YYYY,1,4) || '년 ' || SUBSTR(TOP3_BAS_YYYY,5,6) || '회차' AS TOP3_BAS_YYYY
 , TOP3_RISK_VAL || '점' AS TOP3_RISK_VAL
 , TOP3_TONGJE_VAL || '%' AS TOP3_TONGJE_VAL
 , TOP3_REMDR_VAL || '점' AS TOP3_REMDR_VAL
 , TOP3_RISK_WAY
 , TOP3_TONGJE_WAY
 , TOP3_REMDR_WAY
 , SUBSTR(TOP3_PRE_BAS_YYYY,1,4) || '년 ' || SUBSTR(TOP3_PRE_BAS_YYYY,5,6) || '회차' AS TOP3_PRE_BAS_YYYY
 , TOP3_PRE_RISK_VAL || '점' AS TOP3_PRE_RISK_VAL
 , TOP3_PRE_TONGJE_VAL || '%' AS TOP3_PRE_TONGJE_VAL
 , TOP3_PRE_REMDR_VAL || '점' AS TOP3_PRE_REMDR_VAL
 , (SELECT B.DPRT_NM FROM NIC41B B WHERE B.DPRT_CD = TOP4_BRNO) AS TOP4_BRNO
 , SUBSTR(TOP4_BAS_YYYY,1,4) || '년 ' || SUBSTR(TOP4_BAS_YYYY,5,6) || '회차' AS TOP4_BAS_YYYY
 , TOP4_RISK_VAL || '점' AS TOP4_RISK_VAL
 , TOP4_TONGJE_VAL || '%' AS TOP4_TONGJE_VAL
 , TOP4_REMDR_VAL || '점' AS TOP4_REMDR_VAL
 , TOP4_RISK_WAY
 , TOP4_TONGJE_WAY
 , TOP4_REMDR_WAY
 , SUBSTR(TOP4_PRE_BAS_YYYY,1,4) || '년 ' || SUBSTR(TOP4_PRE_BAS_YYYY,5,6) || '회차' AS TOP4_PRE_BAS_YYYY
 , TOP4_PRE_RISK_VAL || '점' AS TOP4_PRE_RISK_VAL
 , TOP4_PRE_TONGJE_VAL || '%' AS TOP4_PRE_TONGJE_VAL
 , TOP4_PRE_REMDR_VAL || '점' AS TOP4_PRE_REMDR_VAL
 , (SELECT B.DPRT_NM FROM NIC41B B WHERE B.DPRT_CD = TOP5_BRNO) AS TOP5_BRNO
 , SUBSTR(TOP5_BAS_YYYY,1,4) || '년 ' || SUBSTR(TOP5_BAS_YYYY,5,6) || '회차' AS TOP5_BAS_YYYY
 , TOP5_RISK_VAL || '점' AS TOP5_RISK_VAL
 , TOP5_TONGJE_VAL || '%' AS TOP5_TONGJE_VAL
 , TOP5_REMDR_VAL || '점' AS TOP5_REMDR_VAL
 , TOP5_RISK_WAY
 , TOP5_TONGJE_WAY
 , TOP5_REMDR_WAY
 , SUBSTR(TOP5_PRE_BAS_YYYY,1,4) || '년 ' || SUBSTR(TOP5_PRE_BAS_YYYY,5,6) || '회차' AS TOP5_PRE_BAS_YYYY
 , TOP5_PRE_RISK_VAL || '점' AS TOP5_PRE_RISK_VAL
 , TOP5_PRE_TONGJE_VAL || '%' AS TOP5_PRE_TONGJE_VAL
 , TOP5_PRE_REMDR_VAL || '점' AS TOP5_PRE_REMDR_VAL
 , TOP_NOTE
 , WEAK_PT1_NM
 , WEAK_PT2_NM
 , WEAK_PT3_NM
 , WEAK_PT4_NM
 , WEAK_PT5_NM
 , WEAK_PT1_NOTE
 , WEAK_PT2_NOTE
 , WEAK_PT3_NOTE
 , WEAK_PT4_NOTE
 , WEAK_PT5_NOTE
  , UPGRADE_REQ_CNT || '건' AS UPGRADE_REQ_CNT
 , UPGRADE_ACT_CNT || '건' AS UPGRADE_ACT_CNT
 , UPGRADE_ACT_RATE || '%' AS UPGRADE_ACT_RATE
 , UPGRADE_NOTE
 , BRNO_UPGRADE_REQ_CNT || '건' AS BRNO_UPGRADE_REQ_CNT
 , BRNO_UPGRADE_ACT_CNT || '건' AS BRNO_UPGRADE_ACT_CNT
 , BRNO_UPGRADE_ACT_RATE || '%' AS BRNO_UPGRADE_ACT_RATE
 , BRNO_UPGRADE_NOTE
 , UPGRADE_WEAK1_NM
 , UPGRADE_WEAK2_NM
 , UPGRADE_WEAK3_NM
 , UPGRADE_WEAK4_NM
 , UPGRADE_WEAK1_NOTE
 , UPGRADE_WEAK2_NOTE
 , UPGRADE_WEAK3_NOTE
 , UPGRADE_WEAK4_NOTE
 , UPGRADE_WEAK1_BRNO
 , UPGRADE_WEAK2_BRNO
 , UPGRADE_WEAK3_BRNO
 , UPGRADE_WEAK4_BRNO
 FROM   SRBA_VALT_SCHD_R A
WHERE BAS_YYMM = $P{BAS_YYMM}]]>
		</queryString>
