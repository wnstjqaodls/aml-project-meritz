<?xml version="1.0" encoding="UTF-8" ?>
<!-- UTF-8 처리 -->

<!DOCTYPE configuration
PUBLIC "-//ibatis.apache.org//DTD Config 3.0//EN"
"http://ibatis.apache.org/dtd/ibatis-3-config.dtd">
<configuration>
	
	<typeAliases>
		<typeAlias alias="DataObj" type="com.gtone.aml.basic.common.data.DataObj"/>
	</typeAliases>
	
	<environments default="development2">
		<environment id="development2">
			<transactionManager type="JDBC"/>
			<dataSource type="JNDI">
				<property name="data_source" value="java:comp/env/jdbc/AMLDS_WF"/>
			</dataSource>
		</environment>
	</environments>
	
	
	<mappers>
		<mapper resource="com/gtone/aml/sql/AML_100.xml"/>
	</mappers>
</configuration>